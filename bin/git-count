#!/usr/bin/env bash

if test "$1" = "--all"; then
  git shortlog -n -s | awk '{print substr($0,index($0,$2)) " (" $1 ")"}'
  echo
fi

# BUG FIX: The original script used 'HEAD^' which excluded the last commit.
# I removed the '^' to ensure the total count includes all commits up to the current HEAD.
echo total "$(git rev-list --count HEAD)"
